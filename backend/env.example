# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database (MySQL 8) ───────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=sfmisystem

# ── CORS ─────────────────────────────────────────────────────────────────────
# dev: comma-separated list of allowed origins
# prod: must be set to production frontend domain (NOT *)
CORS_ORIGIN=http://localhost:3001,http://localhost:4200

# ── JWT ──────────────────────────────────────────────────────────────────────
# REQUIRED in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
JWT_SECRET=change-this-to-a-random-256-bit-secret

# ── Business rules ───────────────────────────────────────────────────────────
# วงเงินที่ต้องมีคณะกรรมการตรวจรับ (บาท) — ตามระเบียบพัสดุ
COMMITTEE_THRESHOLD=5000

# ── Monitoring (optional) ────────────────────────────────────────────────────
# Set to enable Sentry error tracking + global exception filter
SENTRY_DSN=

# ── AI Configuration ─────────────────────────────────────────────────────────
# Provider selection: openrouter | gemini | ollama
AI_DEFAULT_PROVIDER=openrouter

# OpenRouter (recommended — proxies Gemini/Claude/etc via OpenAI-compatible API)
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Gemini direct (alternate — get key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Ollama local (free, requires local install)
OLLAMA_BASE_URL=
OLLAMA_MODEL=
